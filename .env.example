# Database
DATABASE_URL="postgresql://aml:aml_secret@localhost:5432/aml_detector"

# Redis
REDIS_URL="redis://localhost:6379"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# API
API_PORT=3001
API_SECRET="change-me-in-production"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Python detector service
DETECTOR_URL="http://localhost:8001"

# Multi-tenant
DEFAULT_TENANT_ID="default"

# Authentication — JWT
# Generate a secret: openssl rand -hex 32
JWT_SECRET="change-me-must-be-at-least-32-characters-long"
# Disable in production: AUTH_DEV_ENABLED=false
AUTH_DEV_ENABLED=true

# AML thresholds (override per jurisdiction)
# EU/EEA defaults — adjust for UK (£10k), US ($10k), etc.
AML_SMURFING_THRESHOLD=9000
AML_VELOCITY_WINDOW_HOURS=24
AML_VELOCITY_COUNT_THRESHOLD=5
AML_ROUND_TRIP_HOURS=72
